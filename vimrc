" basic configs
set encoding=utf-8

syntax on
set nocompatible
set showmode
set showcmd
filetype indent on

" number
set number
set relativenumber

" indent
set autoindent
set tabstop=2
set shiftwidth=2
set expandtab
set softtabstop=2

" appearance
set wrap
set linebreak
set wrapmargin=2

" search
set showmatch
set hlsearch
set incsearch
set ignorecase

" edit
set noerrorbells
set history=50
set autoread
set wildmenu

